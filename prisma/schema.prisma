// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  name      String
  account   String    @unique
  email     String    @unique
  hash      String
  groups    Group[]   
  status    Boolean   @default(true)

  @@map("users")
}

model Group {
  id         Int      @id @default(autoincrement())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  name        String  @unique
  description String?
  sort        Int     @default(0)
  status      Boolean @default(true)
  users       User[]
  permissions Permission[]

  @@map("groups")
}

model Customer {
  id        String   @id @default(uuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  email     String    @unique
  hash      String
  name      String
  mobile    String
  address   String
  birthday  DateTime? @db.Date
  gender    Gender  @default(unknown)

  @@map("customers")
}

enum Gender {
  male
  female
  unknown
}

model Category {
  id        Int     @id @default(autoincrement())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  name      String  @unique
  status    Boolean @default(true)

  products  Product[]

  @@map("categories")
}

model Product {
  id          Int       @id @default(autoincrement())
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  name        String    @unique
  number      String?   @unique
  description String?
  price       Float
  cover       String
  images      String[]
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  status      Boolean   @default(true)
  stock       Int       @default(0)

  @@map("products")
}

model File {
  id          Int      @id @default(autoincrement())
  filename    String
  path        String   
  mimetype    String
  description String?

  created_at   DateTime @default(now())

  @@map("files")
}

model Permission {
  id          Int      @id @default(autoincrement())
  subject     String
  action      String
  groups      Group[]

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([subject, action])
  @@map("permissions")
}

model Order {
  id              String   @id @default(uuid())
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  order_status    String   @default("pending")
  payment_status  String   @default("unpaid")
  delivery_status String   @default("undelivered")
  
  order_number    String   @unique
  items           Json     
  total_price     Float

  payment_method  String   
  delivery_method String 
  
  customer        String
  mobile          String
  email           String
  shipping_address String
  memo            String?

  @@map("orders")
}